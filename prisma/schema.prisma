generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  tractors      Tractor[]
  bookings      Booking[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tractor {
  id            String       @id @default(cuid())
  ownerId       String
  owner         User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  model         String
  brand         String
  numberPlate   String       @unique
  year          Int
  hp            Int
  rating        Float        @default(0)
  reviewCount   Int          @default(0)
  pricePerHour  Int
  pricePerDay   Int
  availableTime String
  location      String
  image         String
  images        String       // JSON stringified array
  category      String
  description   String
  available     Boolean      @default(true)
  attachments   Attachment[]
  reviews       Review[]
  bookings      Booking[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Attachment {
  id           String  @id @default(cuid())
  tractorId    String
  tractor      Tractor @relation(fields: [tractorId], references: [id], onDelete: Cascade)
  name         String
  pricePerHour Int
}

model Review {
  id         String   @id @default(cuid())
  tractorId  String
  tractor    Tractor  @relation(fields: [tractorId], references: [id], onDelete: Cascade)
  renterName String
  rating     Int
  comment    String
  date       String
  createdAt  DateTime @default(now())
}

model Booking {
  id              String   @id @default(cuid())
  tractorId       String
  tractor         Tractor  @relation(fields: [tractorId], references: [id], onDelete: Cascade)
  renterId        String
  renter          User     @relation(fields: [renterId], references: [id], onDelete: Cascade)
  startDate       String
  endDate         String
  startTime       String?
  endTime         String?
  duration        Int
  durationType    String   // "hours" or "days"
  attachments     String   // JSON stringified array of names
  baseRent        Float
  attachmentTotal Float
  platformFee     Float
  gst             Float
  grandTotal      Float
  status          String   // "pending", "accepted", "declined", "paid", "cancelled"
  paymentId       String?
  bookedAt        DateTime @default(now())
}
